      <column caption='Total Tweets' datatype='integer' name='[Calculation_2510193905578446848]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([tweet])' />
      </column>
      <column caption='Positive %' datatype='real' name='[Calculation_2510193905578770433]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [sentiment] = &apos;Positive&apos; THEN 1 ELSE 0 END) / COUNT([tweet])' />
      </column>
      <column caption='Negative %' datatype='real' name='[Calculation_2510193905579261954]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [sentiment] = &apos;Negative&apos; THEN 1 ELSE 0 END) / COUNT([tweet])' />
      </column>
      <column caption='Tweets per Domain' datatype='integer' name='[Calculation_2510193905579429891]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [domain] : COUNT([tweet]) }' />
      </column>
      <column caption='KPI label' datatype='real' name='[Calculation_2510193905585295369]' role='measure' type='quantitative'>
